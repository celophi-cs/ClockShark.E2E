# GitHub PAT for cloning ClockShark repo (needs repo read access)
GIT_TOKEN=

# Git branch to build (default: main)
# GIT_BRANCH=main

# Azure DevOps PAT for ClockShark.Libraries NuGet feed (needs Packaging Read)
NUGET_PAT=

# Base URL for the app under test (default: https://localhost:30080)
# BASE_URL=https://localhost:30080

# Anthropic API key for AI test runner (only needed for npm run test:ai)
ANTHROPIC_API_KEY=
