# GIT_BRANCH=main

# Azure DevOps PAT for ClockShark.Libraries NuGet feed (needs Packaging Read)
NUGET_PAT=

# Base URL for the app under test (default: http://localhost:30080)
# BASE_URL=http://localhost:30080
