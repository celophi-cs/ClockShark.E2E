{
  "name": "clockshark-e2e",
  "version": "1.0.0",
  "description": "End-to-end tests for ClockShark using Playwright",
  "private": true,
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:ui": "npx playwright test --ui",
    "test:debug": "npx playwright test --debug",
    "test:ai": "npx tsx ai-runner.ts",
    "test:ai:regen": "npx tsx ai-runner.ts --force-regen",
    "test:all": "npm run test:ai && npx playwright test",
    "report": "npx playwright show-report",
    "infra:up": "podman compose -f docker/compose.e2e.yaml --env-file .env -p clockshark-e2e up -d --build",
    "infra:down": "podman compose -f docker/compose.e2e.yaml --env-file .env -p clockshark-e2e down --volumes --remove-orphans",
    "infra:logs": "podman compose -f docker/compose.e2e.yaml --env-file .env -p clockshark-e2e logs -f"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@playwright/test": "^1.50.0",
    "dotenv": "^16.4.7",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0"
  }
}
